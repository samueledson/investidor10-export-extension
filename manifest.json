{
  "manifest_version": 3,
  "name": "Investidor10 Export",
  "version": "0.1.0",
  "description": "Exporta as posições da carteira do Investidor10 para CSV e PDF.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://investidor10.com.br/*"],
  "icons": {
    "24": "icon-light.png"
  },
  "action": {
    "default_icon": {
      "24": "icon-light.png"
    },
    "default_popup": "popup.html",
    "default_title": "Exportar Investidor10"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://investidor10.com.br/wallet/my-wallet/positions*",
        "https://investidor10.com.br/wallet/my-wallet/*/positions*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
